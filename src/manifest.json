{
  "package": "com.woisol.wargametab",
  "name": "WargameTabWatch",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1000,
  "icon": "/common/logo.png",
  "deviceTypeList": [
    "watch"
  ],
  "features": [
    {
      "name": "system.router"
    },
    {
      "name": "system.storage"
    },
    {
      "name": "system.vibrator"
    },
    {
      "name": "system.interconnect"
    },
    {
      "name": "system.prompt"
    }
  ],
  "config": {
    "logLevel": "log",
    "designWidth": "device-width"
  },
  "router": {
    "entry": "pages/index",
    "pages": {
      "pages/index": {
        "component": "index"
      },
      "pages/history": {
        "component": "history"
      },
      "pages/review": {
        "component": "review"
      },
      "pages/settings": {
        "component": "settings"
      },
      "pages/settings-option": {
        "component": "settings-option"
      }
    }
  }
}
